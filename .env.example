# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Google Gemini
VITE_GEMINI_API_KEY=your-gemini-api-key
VITE_GEMINI_MODEL=gemini-2.5-flash

# Supabase Storage buckets (optional — defaults used if omitted)
VITE_SUPABASE_RESOURCE_BUCKET=teacher-resources
VITE_SUPABASE_HISTORY_BUCKET=student-history
